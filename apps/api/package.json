{
  "name": "@callora/api",
  "version": "0.1.0",
  "private": true,
  "description": "Tenant-safe HTTP API for Callora.",
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development DEV_AUTH_ENABLED=true tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:report-worker": "node dist/report-worker-server.js",
    "pii:backfill": "tsx src/tools/call-pii-backfill.ts backfill",
    "pii:rotate": "tsx src/tools/call-pii-backfill.ts rotate",
    "pii:verify": "tsx src/tools/call-pii-backfill.ts verify",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@callora/contracts": "file:../../packages/contracts",
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "jose": "^6.2.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  }
}
