{
  "name": "@callora/database",
  "version": "0.1.0",
  "private": true,
  "description": "PostgreSQL schema, migrations, seed data, and verification for Callora.",
  "type": "module",
  "files": [
    "access",
    "migrations",
    "operations",
    "seed",
    "tests",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "verify": "node scripts/verify-schema.mjs",
    "migrate": "node scripts/run-sql.mjs migrate",
    "seed": "node scripts/run-sql.mjs seed/dev.sql",
    "bootstrap:production": "node scripts/run-sql.mjs seed/production.sql",
    "roles:bootstrap": "node scripts/run-sql.mjs access/bootstrap-roles.sql",
    "access:apply": "node scripts/run-sql.mjs access/roles.sql",
    "pii:finalize": "node scripts/run-sql.mjs operations/finalize-call-pii.sql",
    "verify:live": "node scripts/run-sql.mjs tests/live-schema.sql",
    "verify:phase3d": "node scripts/phase3d-live.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
