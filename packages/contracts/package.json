{
  "name": "@callora/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared, dependency-free TypeScript contracts for Callora clients and services.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "tsc -b tsconfig.json --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
