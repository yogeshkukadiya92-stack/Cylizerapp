# Callora API. Production must supply a unique secret of 32+ characters.
NODE_ENV=development
HOST=127.0.0.1
PORT=4100
DEV_AUTH_ENABLED=true
AUTH_SECRET=replace-with-a-random-local-secret-at-least-32-characters
AUTH_TOKEN_TTL_SECONDS=28800
PAIRING_CODE_TTL_SECONDS=600
DEVICE_BOOTSTRAP_TTL_SECONDS=600
DEVICE_SESSION_TTL_SECONDS=604800
PAIRING_ATTEMPT_LIMIT=5
PAIRING_ATTEMPT_WINDOW_SECONDS=60
# Leave empty for a directly exposed API. Behind a reverse proxy, list only the
# exact proxy CIDRs; /0 networks and arbitrary forwarded headers are rejected.
TRUSTED_PROXY_CIDRS=
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Web authentication. `dev` uses the local-only API session route. For a real
# deployment switch to `oidc` and register these exact redirect URLs at the IdP.
VITE_API_URL=http://localhost:4100
VITE_AUTH_MODE=dev
VITE_DEV_ORGANIZATION_ID=org_alpha
VITE_DEV_ROLE=owner
VITE_OIDC_AUTHORITY=https://identity.example.com
VITE_OIDC_CLIENT_ID=replace-with-public-spa-client-id
VITE_OIDC_REDIRECT_URI=http://localhost:4173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:4173/auth/logout-callback
VITE_OIDC_SCOPE=openid profile email callora-api

# API OIDC trust boundary (required when NODE_ENV=production). The organization
# claim must be a signed top-level claim containing the Callora organization UUID.
OIDC_ISSUER=https://identity.example.com
OIDC_AUDIENCE=callora-api
OIDC_JWKS_URI=https://identity.example.com/.well-known/jwks.json
OIDC_ORGANIZATION_CLAIM=https://callora.example/claims/organization_id
OIDC_ALLOWED_ALGORITHMS=RS256
OIDC_CLOCK_TOLERANCE_SECONDS=5

# PostgreSQL / bounded production pool
DATABASE_URL=postgresql://callora:callora-local-password@127.0.0.1:5432/callora
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_LOCK_TIMEOUT_MS=1000
DATABASE_SSL_MODE=disable

# Call-log phone/name protection. Generate pairwise-independent 32-byte
# encryption, blind-index, and stable row-ID keys in the deployment secret
# store; there are no defaults. Keep older rotating versions during rotation
# and make the highest version in each keyring active.
CALL_PII_ENCRYPTION_KEYS=1:<replace-with-base64url-32-byte-key>
CALL_PII_ACTIVE_KEY_VERSION=1
CALL_PII_BLIND_INDEX_KEYS=1:<replace-with-independent-base64url-32-byte-key>
CALL_PII_ACTIVE_BLIND_INDEX_KEY_VERSION=1
CALL_PII_ROW_ID_KEY=<replace-with-independent-stable-base64url-32-byte-key>

# PII backfill/verification CLI only; never persist these two variables in the
# long-running API environment. Process one tenant at a time after backup. The
# CLI additionally requires DATABASE_SSL_MODE=verify-full and a short-lived
# LOGIN whose only Callora membership is callora_pii_migrator.
# CALL_PII_BACKFILL_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
# CALL_PII_BACKFILL_BATCH_SIZE=100

# Phase 3D deployment verification inputs. These placeholders intentionally fail
# closed until replaced by deployed HTTPS origins and the real proxy topology.
PHASE3D_WEB_ORIGIN=https://app.example.com
PHASE3D_API_ORIGIN=https://api.example.com
PHASE3D_EXPECT_PROXY=true
PHASE3D_DATABASE_SSL_MODE=verify-full
PHASE3D_ALLOW_INSECURE_LOCALHOST=false

# Android release endpoint/signing inputs. Passwords and the keystore stay
# outside the repository and are read only from the build process environment.
CALLORA_ANDROID_API_BASE_URL=https://api.example.com
CALLORA_ANDROID_KEYSTORE_PATH=/absolute/path/outside/repository/callora-release.jks
CALLORA_ANDROID_KEY_ALIAS=callora-release
CALLORA_ANDROID_KEYSTORE_PASSWORD=<inject-from-secret-store>
CALLORA_ANDROID_KEY_PASSWORD=<inject-from-secret-store>
